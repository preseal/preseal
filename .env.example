# preseal configuration
#
# preseal does NOT call any LLM API directly — it imports YOUR agent
# and calls .invoke(). Set whichever API key your agent needs.
#
# Only needed for `preseal scan` (adversarial testing with real LLM).
# NOT needed for `preseal audit` (static analysis) or `preseal scan --demo`.

# --- Set the key(s) YOUR agent uses ---

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google
# GOOGLE_API_KEY=...

# Nebius / OpenAI-compatible
# NEBIUS_API_KEY=...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Local models (Ollama, vLLM, etc.) — no key needed
# OLLAMA_BASE_URL=http://localhost:11434
